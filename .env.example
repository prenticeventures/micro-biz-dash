# Feature flag: set to 1 to re-enable sign-in, cloud save, and leaderboard features
# Default product mode is guest-only, so leaving this unset keeps online services off.
# VITE_ENABLE_ONLINE_SERVICES=1

# Only required when VITE_ENABLE_ONLINE_SERVICES=1
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-key

# Optional local tooling only (never used in app runtime)
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
